# Salin ke .env: cp .env.example .env

# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=hrm_wfh_db

# Server
PORT=3000
NODE_ENV=development

# JWT (ganti di production)
JWT_SECRET=ubah_jadi_string_rahasia_panjang
JWT_EXPIRATION=7d

# CORS — URL frontend
FRONTEND_URL=http://localhost:3001

# Seed user demo saat startup (admin@example.com / emp@example.com, password: password123)
SEED_DEMO_USERS=true
SEED_FORCE_RESET=false

# Registrasi publik /auth/register (false = hanya admin buat karyawan)
ALLOW_PUBLIC_REGISTER=false
